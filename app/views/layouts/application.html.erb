<!DOCTYPE html>
<html class="min-vh-100">
  <head>
    <title>Purchasing</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script>
      // Apply the saved theme before paint so there's no flash. Must stay
      // inline + non-deferred for that reason.
      (function() {
        try {
          var stored = localStorage.getItem('theme') || 'auto';
          var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored === 'auto' ? (systemDark ? 'dark' : 'light') : stored;
          document.documentElement.setAttribute('data-bs-theme', theme);
        } catch (e) { /* localStorage may be blocked; fall back to default */ }
      })();
    </script>
    <%= stylesheet_link_tag "application", media: "all", 'data-turbo-track': "reload" %>
    <%= javascript_include_tag "application", 'data-turbo-track': "reload", defer: true %>
    <%= render 'application/favicon' %>
    <script>
      window.onload = function() {
          var isUnsupported = (window.navigator.userAgent.indexOf("Edg") != -1) ||
                              (window.navigator.userAgent.indexOf("IE") != -1) ||
                              (window.navigator.userAgent.indexOf("Trident") != -1)
          if(isUnsupported && window.location.pathname != "/pages/browsers") {
            window.location.href = "<%= pages_browsers_url %>";
          }
      }
    </script>
  </head>
  <body class="d-flex flex-column min-vh-100">
    <% if current_account %>
      <nav class="navbar navbar-expand-md fixed-top bg-primary" data-bs-theme="dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="#"></a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse" aria-controls="navbarCollapse" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarCollapse">
            <ul class="navbar-nav me-auto mb-2 mb-md-0">
              <li class="nav-item">
                <%= link_to "Requests", requests_path, class: 'nav-link' %>
              </li>
              <li class="nav-item">
                <%= link_to "Reports", reports_path, class: 'nav-link' %>
              </li>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  Resources
                </a>
                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                  <li><%= link_to 'Clients', clients_path, class: 'dropdown-item' %></li>
                  <li><%= link_to 'Projects', projects_path, class: 'dropdown-item' %></li>
                  <li><%= link_to 'Payment methods', payment_methods_path, class: 'dropdown-item' %></li>
                </ul>
              </li>
            </ul>
            <ul class="navbar-nav ms-auto mb-2 mb-md-0">
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="themeMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Theme">
                  <i id="theme-toggle-icon" class="fa-solid fa-circle-half-stroke"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="themeMenu">
                  <li>
                    <button type="button" class="dropdown-item" data-bs-theme-value="light">
                      <i class="fa-solid fa-sun me-2"></i>Light
                    </button>
                  </li>
                  <li>
                    <button type="button" class="dropdown-item" data-bs-theme-value="dark">
                      <i class="fa-solid fa-moon me-2"></i>Dark
                    </button>
                  </li>
                  <li>
                    <button type="button" class="dropdown-item" data-bs-theme-value="auto">
                      <i class="fa-solid fa-circle-half-stroke me-2"></i>Auto
                    </button>
                  </li>
                </ul>
              </li>
              <li class="nav-item">
                <% if current_account %>
                  <%= link_to(accounts_sign_out_path, class: 'nav-link') do %>
                    <i class="fa-solid fa-right-from-bracket"></i>
                  <% end %>
                <% else %>
                  <%= link_to(sign_in_path, class: 'nav-link') do %>
                    <i class="fa-solid fa-right-to-bracket"></i>
                  <% end %>
                <% end %>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    <% end %>
    <main class="container flex-shrink-0">
      <% if notice %>
        <div class="alert alert-primary alert-dismissible fade show" role="alert">
          <%= notice %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <% if alert %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
          <%= alert %>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <footer class="footer mt-auto py-3 bg-body-tertiary">
      <div class="container">
        <div class="row">
          <span class="col-md-6">
            © 2017-<%= Time.zone.now.year %> - Product Concept Development, Inc.
          </span>
          <span class="col-md-6 text-muted text-md-end">Purchasing <%= "#{REVISION}" %></span>
        </div>
      </div>
    </footer>
  </body>
</html>
