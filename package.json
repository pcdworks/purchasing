{
  "name": "purchasing",
  "private": true,
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.2.1",
    "@hotwired/turbo-rails": "^8.0.0",
    "@nathanvda/cocoon": "^1.2.14",
    "@popperjs/core": "^2.11.2",
    "@rails/actioncable": "^7.0.0",
    "@rails/activestorage": "^7.0.0",
    "@rails/ujs": "^7.0.0",
    "bootstrap": "^5.1.3",
    "esbuild": "^0.21.0",
    "jquery": "^3.6.0",
    "sass": "^1.77.0"
  },
  "scripts": {
    "build": "esbuild app/javascript/application.js --bundle --sourcemap --outdir=app/assets/builds --public-path=/assets",
    "build:css": "yarn build:fonts && sass ./app/assets/stylesheets/application.bootstrap.scss ./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:fonts": "mkdir -p public/fonts && cp -R node_modules/@fortawesome/fontawesome-free/webfonts/. public/fonts/"
  },
  "version": "0.1.0",
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
